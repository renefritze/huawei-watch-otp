{
  "app": {
    "signingConfigs": [
      {
        "name": "default",
        "type": "HarmonyOS",
        "material": {
          // Populated at build time via sed (CI) or by placing real files in signing/.
          // See README.md § "One-time signing setup" for full instructions.
          "storePassword": "__STORE_PASSWORD__",
          "keyAlias": "otp_watch_key",
          "keyPassword": "__KEY_PASSWORD__",
          "profile": "./signing/profile.p7b",
          "signAlg": "SHA256withECDSA",
          "certpath": "./signing/otp_watch.cer",
          "storeFile": "./signing/otp_watch.p12"
        }
      }
    ],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "3.1.0(6)",
        "targetSdkVersion": "3.1.0(7)",
        "runtimeOS": "HarmonyOS"
      }
    ],
    "buildModeSet": [
      { "name": "debug"   },
      { "name": "release" }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [ "default" ]
        }
      ]
    }
  ]
}
